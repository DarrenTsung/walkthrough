    "",
    "// WorkspaceHandler handles workspace management operations (workspace/*).",
    "type WorkspaceHandler struct {",
    "\tserver  Server",
    "\tmetrics *metrics.Reporter",
    "}",
    "",
    "// NewWorkspaceHandler creates a new workspace handler.",
    "func NewWorkspaceHandler(server Server, metricsReporter *metrics.Reporter) *WorkspaceHandler {",
    "\treturn &WorkspaceHandler{server: server, metrics: metricsReporter}",
    "}",
    "",
    "// Create handles workspace/create requests.",
    "// This is a write operation (requires write permission).",
    "// Bootstrap config is required. The handler creates the workspace directory and",
    "// returns immediately while bootstrap runs asynchronously in a goroutine.",
    "// Prompts gate on WaitForReadyAndResolve, which blocks until the workspace",
    "// reaches Ready state.",
    "func (h *WorkspaceHandler) Create(ctx context.Context, req *proto.WorkspaceCreateRequest) (*proto.WorkspaceCreateResponse, error) {",
    "\tif req.Bootstrap == nil {",
    "\t\treturn nil, &HandlerError{Code: \"invalid_argument\", Message: \"bootstrap config is required\"}",
    "\t}",
    "\tif err := req.Bootstrap.Validate(); err != nil {",
    "\t\treturn nil, err",
    "\t}",
    "",
    "\twsMgr := h.server.WorkspaceManager()",
    "",
    "\t// Resolve workspace ID with fallback to default, matching other endpoints.",
    "\twsID := req.WorkspaceID",
    "\tif wsID.IsZero() {",
    "\t\twsID = proto.DefaultWorkspaceID",
    "\t}",
    "",
    "\twsID, metadata, created, err := wsMgr.CreateWorkspace(wsID, req.Env)",
    "\tif err != nil {",
    "\t\treturn nil, fmt.Errorf(\"create workspace: %w\", err)",
    "\t}",
    "",
    "\tif h.metrics != nil {",
    "\t\th.metrics.RecordWorkspaceCreate(\"true\")",
    "\t}",
    "",
    "\t// Non-blocking bootstrap: spawns a goroutine tracked by bootstrapWg",
    "\t// for graceful shutdown. The goroutine transitions the workspace from",
    "\t// Ready to Creating (via CreateWorkspaceForBootstrap), runs bootstrap,",
    "\t// then transitions to Ready on success or Failed on error. Prompts",
    "\t// arriving before bootstrap completes block on WaitForReadyAndResolve.",
    "\th.server.BootstrapWorkspaceAsync(ctx, wsID, req.Bootstrap)",
    "",
    "\treturn &proto.WorkspaceCreateResponse{",
    "\t\tWorkspaceID: wsID,",
    "\t\tMetadata:    metadata,",
    "\t\tCreated:     created,",
    "\t}, nil",
    "}",
    "",
    "// List handles workspace/list requests.",
    "// Named List to match message type and read-only (List prefix).",
    "func (h *WorkspaceHandler) List(ctx context.Context, req *proto.WorkspaceListRequest) (*proto.WorkspaceListResponse, error) {",
    "\twsMgr := h.server.WorkspaceManager()",
    "\tworkspaces := wsMgr.ListWorkspaces()",
    "",
    "\treturn &proto.WorkspaceListResponse{",
    "\t\tWorkspaces: workspaces,",
    "\t}, nil",
    "}",
    "",
    "// Status handles workspace/status requests.",
    "// Named Status to match message type and read-only (Status prefix).",
    "func (h *WorkspaceHandler) Status(ctx context.Context, req *proto.WorkspaceStatusRequest) (*proto.WorkspaceStatusResponse, error) {",
    "\twsMgr := h.server.WorkspaceManager()",
    "",
    "\t// Resolve workspace ID with fallback to default",
    "\twsID := req.WorkspaceID",
    "\tif wsID.IsZero() {",
    "\t\twsID = proto.DefaultWorkspaceID",
    "\t}",
    "",
    "\tstatus := wsMgr.GetWorkspaceStatus(wsID, req.RepoIDs)",
    "\tif status == nil {",
    "\t\treturn nil, ErrWorkspaceNotFound",
    "\t}",
    "",
    "\treturn &proto.WorkspaceStatusResponse{",
    "\t\tWorkspaceID:  status.WorkspaceID,",
    "\t\tMetadata:     status.Metadata,",
    "\t\tRepositories: status.Repositories,",
    "\t}, nil",
    "}",
    "",
    "// Delete handles workspace/delete requests.",
    "// This is a write operation (requires write permission).",
    "func (h *WorkspaceHandler) Delete(ctx context.Context, req *proto.WorkspaceDeleteRequest) (*proto.WorkspaceDeleteResponse, error) {",
    "\twsMgr := h.server.WorkspaceManager()",
    "",
    "\tif req.WorkspaceID.IsZero() {",
    "\t\treturn nil, &HandlerError{Code: \"invalid_argument\", Message: \"workspaceId is required\"}",
    "\t}",
    "",
    "\terr := wsMgr.DeleteWorkspace(req.WorkspaceID)",
    "\tif err != nil {",
    "\t\treturn nil, err",
    "\t}",
    "",
    "\th.server.EvictBootstrapCache(req.WorkspaceID)",
    "",
    "\treturn &proto.WorkspaceDeleteResponse{",
    "\t\tSuccess: true,",
    "\t}, nil",
    "}",
    "",
    "// SetupRepos handles workspace/setup_repos requests.",
    "// This is a write operation (requires write permission).",
    "func (h *WorkspaceHandler) SetupRepos(ctx context.Context, req *proto.WorkspaceSetupReposRequest) (*proto.WorkspaceSetupReposResponse, error) {",
    "\twsMgr := h.server.WorkspaceManager()",
    "",
    "\t// Resolve workspace ID with fallback to default",
    "\twsID := req.WorkspaceID",
    "\tif wsID.IsZero() {",
    "\t\twsID = proto.DefaultWorkspaceID",
    "\t}",
    "",
    "\t// Verify workspace exists",
    "\tstatus := wsMgr.GetWorkspaceStatus(wsID, nil)",
    "\tif status == nil {",
    "\t\treturn nil, ErrWorkspaceNotFound",
    "\t}",
    "",
    "\t// Convert to pointer slice for workspace manager",
    "\trepos := make([]*proto.Repository, len(req.Repositories))",
    "\tfor i := range req.Repositories {",
    "\t\trepos[i] = &req.Repositories[i]",
    "\t}",
    "",
    "\trepoStatuses := wsMgr.SetupWorkspaceRepos(wsID, repos, req.Initialize)",
    "",
    "\t// Get workspace metadata",
    "\twsStatus := wsMgr.GetWorkspaceStatus(wsID, nil)",
    "\tvar metadata *proto.WorkspaceMetadata",
    "\tif wsStatus != nil {",
    "\t\tmetadata = wsStatus.Metadata",
    "\t}",
    "",
    "\treturn &proto.WorkspaceSetupReposResponse{",
    "\t\tWorkspaceID:  wsID,",
    "\t\tMetadata:     metadata,",
    "\t\tRepositories: repoStatuses,",
    "\t}, nil",
    "}",
    "",
    "// Save handles workspace/save requests.",
    "// This is a write operation (requires write permission).",
    "func (h *WorkspaceHandler) Save(ctx context.Context, req *proto.WorkspaceSaveRequest) (*proto.WorkspaceSaveResponse, error) {",
    "\twsMgr := h.server.WorkspaceManager()",
    "",
    "\t// Resolve workspace ID with fallback to default",
    "\twsID := req.WorkspaceID",
    "\tif wsID.IsZero() {",
    "\t\twsID = proto.DefaultWorkspaceID",
    "\t}",
    "",
    "\tpush := true",
    "\tif req.Push != nil {",
    "\t\tpush = *req.Push",
    "\t}",
    "",
    "\tresults := wsMgr.SaveWorkspaceRepos(ctx, wsID, req.RepoIDs, req.Message, push)",
    "",
    "\t// Convert pointer slice to value slice for response",
    "\tresultsValue := make([]proto.RepoSaveResult, len(results))",
    "\tfor i, r := range results {",
    "\t\tif r != nil {",
    "\t\t\tresultsValue[i] = *r",
    "\t\t}",
    "\t}",
    "",
    "\treturn &proto.WorkspaceSaveResponse{",
    "\t\tWorkspaceID: wsID,",
    "\t\tResults:     resultsValue,",
    "\t}, nil",
    "}",
    "",
    "// UpdateCredentials handles workspace/update_credentials requests.",
    "// This is a write operation (requires write permission).",
    "func (h *WorkspaceHandler) UpdateCredentials(ctx context.Context, req *proto.WorkspaceUpdateCredentialsRequest) (*proto.WorkspaceUpdateCredentialsResponse, error) {",
    "\twsMgr := h.server.WorkspaceManager()",
    "",
    "\t// Resolve workspace ID with fallback to default",
    "\twsID := req.WorkspaceID",
    "\tif wsID.IsZero() {",
    "\t\twsID = proto.DefaultWorkspaceID",
    "\t}",
    "",
    "\tif req.RepoID.IsZero() {",
    "\t\treturn nil, &HandlerError{Code: \"invalid_argument\", Message: \"repoId is required\"}",
    "\t}",
    "",
    "\terr := wsMgr.UpdateRepoCredentials(wsID, req.RepoID, req.Credentials)",
    "",
    "\tif err != nil {",
    "\t\treturn &proto.WorkspaceUpdateCredentialsResponse{",
    "\t\t\tSuccess: false,",
    "\t\t\tError:   err.Error(),",
    "\t\t}, nil",
    "\t}",
    "",
    "\treturn &proto.WorkspaceUpdateCredentialsResponse{",
    "\t\tSuccess: true,",
    "\t}, nil",
    "}"
